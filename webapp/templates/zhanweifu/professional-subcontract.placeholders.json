      "label": "签订年"
    },
    {
      "key": "signMonth",
      "label": "签订月"
    },
    {
      "key": "signDay",
      "label": "签订日"
    },
    {
      "key": "supplierName",
      "label": "分包方名称"
    },
    {
      "key": "supplierAddress",
      "label": "分包方联系地址"
    },
    {
      "key": "supplierBank",
      "label": "分包方开户银行"
    },
    {
      "key": "supplierAccount",
      "label": "分包方银行账号"
