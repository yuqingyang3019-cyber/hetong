# 阿里云百炼 DashScope（OpenAI-compatible）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_ENABLE_THINKING=true

# 阿里云文字识别 OCR（RecognizeAllText；以下非密钥项已有代码默认值）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_REGION_ID=cn-hangzhou
ALIYUN_OCR_SCENE=Advanced
ALIYUN_OCR_OUTPUT_TABLE=true
ALIYUN_OCR_LINELESS_TABLE=false
